{
  "name": "mindstoria",
  "main": "expo-router/entry",
  "version": "1.0.4",
  "scripts": {
    "start": "expo start",
    "dev": "APP_VARIANT=development expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "patch-package",
    "db:generate": "drizzle-kit generate",
    "build:android:dev": "eas build --platform android --profile development",
    "build:android:prod": "eas build --platform android",
    "build:android:prod:local": "eas build --platform android --local --profile production",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:ios:prod": "eas build --platform ios",
    "build:ios:prod:local": "eas build --platform ios --local --profile production",
    "update:prev": "eas update --environment preview --branch preview --message \"$npm_config_message\"",
    "update:prod": "eas update --environment production --branch production --message \"$npm_config_message\""
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/zain": "^0.4.0",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-vector-icons/feather": "^12.3.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.9.0",
    "@shopify/react-native-skia": "2.2.12",
    "@types/lodash": "^4.17.20",
    "babel-plugin-inline-import": "^3.0.0",
    "dayjs": "^1.11.18",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.6",
    "expo": "~54.0.30",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.9",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-drizzle-studio-plugin": "^0.2.0",
    "expo-file-system": "~19.0.16",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.15",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.5.3",
    "lodash": "^4.17.21",
    "mixpanel-react-native": "^3.2.1",
    "patch-package": "^8.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.0.0",
    "react-native": "0.81.5",
    "react-native-awesome-slider": "^2.9.0",
    "react-native-calendars": "^1.1313.0",
    "react-native-circular-progress": "^1.4.1",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-linear-gradient": "^2.8.3",
