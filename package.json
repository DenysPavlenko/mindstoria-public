    "react-native-snackbar": "^2.9.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-swipeable-item": "^2.0.9",
    "react-native-timer-picker": "^2.3.1",
    "react-native-toggle-element": "^2.1.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "redux-devtools-expo-dev-plugin": "^2.0.0",
    "redux-persist": "^6.0.0",
    "victory-native": "^41.20.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
